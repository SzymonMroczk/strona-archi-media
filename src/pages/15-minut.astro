---
import BaseLayout from '../layouts/BaseLayout.astro';

const instagramUrl = 'https://www.instagram.com/archi_media__/';
const chatUrl = 'https://ig.me/m/archi_media__';

// Po wrzuceniu filmu do Vimeo albo Wistia wklej tutaj link embed.
// Vimeo przykład: https://player.vimeo.com/video/123456789
// Wistia przykład: https://fast.wistia.net/embed/iframe/abc123xyz
const videoEmbedUrl = '';

---

<BaseLayout
  title="15 minut, które odmienią Twoją pracownię | Archi Media"
  description="Krótka lekcja wideo dla właścicieli pracowni wnętrz o marketingu, sprzedaży, CRM i procesie pozyskiwania klientów."
>
  <main class="min-h-screen overflow-hidden bg-archiDark text-archiWhite">
    <section class="relative isolate px-4 pb-14 pt-6 sm:px-5 md:px-8 md:pb-20 md:pt-8">
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_0%,rgba(82,102,233,0.32),transparent_34%),linear-gradient(135deg,#111948_0%,#050608_50%,#050608_100%)]"></div>
      <div class="absolute left-1/2 top-24 -z-10 h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-archiBlue/[0.12] blur-3xl"></div>

      <div class="mx-auto max-w-7xl">
        <header class="mb-9 flex items-center justify-between gap-4 md:mb-12">
          <a href="/" class="inline-flex items-center gap-3 rounded-2xl bg-archiWhite px-3.5 py-2.5 transition-transform duration-200 hover:-translate-y-0.5" aria-label="Archi Media">
            <img src="/assets/archimedia-symbol.png" alt="" class="h-8 w-8" />
            <span class="text-sm font-black uppercase tracking-[0.08em] text-archiBlack">Archi Media</span>
          </a>

          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hidden rounded-full border border-archiWhite/[0.16] bg-archiWhite/[0.06] px-5 py-3 text-sm font-extrabold text-archiWhite/[0.86] transition-all duration-200 hover:-translate-y-0.5 hover:bg-archiWhite/[0.10] sm:inline-flex">
            Instagram
          </a>
        </header>

        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-5 flex flex-wrap justify-center gap-2.5">
            <span class="rounded-full border border-archiWhite/[0.14] bg-archiWhite/[0.08] px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.20em] text-archiWhite/[0.66] sm:text-xs">Meta Ads</span>
            <span class="rounded-full border border-archiWhite/[0.14] bg-archiWhite/[0.08] px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.20em] text-archiWhite/[0.66] sm:text-xs">Sprzedaż</span>
            <span class="rounded-full border border-archiWhite/[0.14] bg-archiWhite/[0.08] px-4 py-2 text-[0.68rem] font-black uppercase tracking-[0.20em] text-archiWhite/[0.66] sm:text-xs">CRM</span>
          </div>

          <p class="mb-4 text-xs font-black uppercase tracking-[0.22em] text-archiBlue sm:text-sm">Lekcja wideo dla pracowni architektonicznych</p>
          <h1 class="text-4xl font-black leading-[0.92] tracking-[-0.065em] text-archiWhite sm:text-5xl md:text-6xl lg:text-[4.8rem]">
            15 minut, które odmienią Twoją pracownię
          </h1>
        </div>

        <div class="mx-auto mt-8 max-w-6xl rounded-[1.6rem] border border-archiWhite/[0.10] bg-archiWhite/[0.06] p-2 shadow-glow backdrop-blur md:mt-10 md:rounded-[2.4rem] md:p-4">
          <div class="relative overflow-hidden rounded-[1.25rem] border border-archiWhite/[0.10] bg-archiBlack md:rounded-[2rem]">
            <div class="aspect-video">
              {videoEmbedUrl ? (
                <iframe
                  src={videoEmbedUrl}
                  title="15 minut, które odmienią Twoją pracownię"
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                  class="h-full w-full"
                ></iframe>
              ) : (
                <div class="flex h-full w-full flex-col items-center justify-center bg-[radial-gradient(circle_at_50%_0%,rgba(82,102,233,0.30),transparent_48%),linear-gradient(135deg,#151a3a,#08090d)] px-5 text-center">
                  <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-archiBlue text-archiWhite shadow-glow md:h-20 md:w-20">
                    <svg class="ml-1 h-7 w-7 md:h-8 md:w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                  <p class="mb-3 text-xl font-black tracking-[-0.04em] md:text-3xl">Miejsce na Twoje wideo</p>
                  <p class="max-w-lg text-sm leading-relaxed text-archiWhite/[0.52] md:text-base">
                    Po wrzuceniu filmu do Vimeo albo Wistia wklej link embed w pliku src/pages/15-minut.astro.
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>

      </div>
    </section>

    <section class="bg-archiDark px-4 py-14 text-archiWhite sm:px-5 md:px-8 md:py-20">
      <div class="mx-auto max-w-6xl">
        <div class="mb-8 text-center md:mb-10">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-archiBlue sm:text-sm">Co dalej</p>
        </div>

        <div class="rounded-[2.2rem] border border-archiWhite/[0.10] bg-archiWhite/[0.06] p-6 text-center shadow-glow md:p-10">
          <h3 class="mx-auto mb-4 max-w-2xl text-3xl font-black leading-[0.96] tracking-[-0.06em] md:text-5xl">Chcesz sprawdzić, co można poprawić w Twojej pracowni?</h3>
          <p class="mx-auto mb-8 max-w-2xl text-base leading-relaxed text-archiWhite/[0.62] md:text-lg">
            Napisz do mnie i umów się na niezobowiązującą konsultację strategiczną.
          </p>
          <div class="flex flex-col justify-center gap-3 sm:flex-row">
            <a href={chatUrl} target="_blank" rel="noopener noreferrer" class="btn-primary w-full sm:w-auto">
              Rozpocznij chat
            </a>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto">
              Mój Instagram
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="border-t border-archiWhite/[0.08] bg-archiDark px-4 py-8 text-archiWhite sm:px-5 md:px-8">
      <div class="mx-auto flex max-w-6xl flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
        <a href="/" class="inline-flex items-center gap-3 rounded-2xl bg-archiWhite px-3.5 py-2.5" aria-label="Archi Media">
          <img src="/assets/archimedia-symbol.png" alt="" class="h-8 w-8" />
          <span class="text-sm font-black uppercase tracking-[0.08em] text-archiBlack">Archi Media</span>
        </a>
        <p class="text-sm font-semibold text-archiWhite/[0.45]">Nowoczesny rozwój pracowni architektonicznych.</p>
      </div>
    </footer>
  </main>
</BaseLayout>
