---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const {
  title = 'Archi Media | Klienci dla architektów wnętrz',
  description = 'Archi Media pomaga architektom wnętrz pozyskiwać klientów przez Meta Ads, sprzedaż, CRM i proces obsługi zapytań.',
  keywords = 'marketing dla architektów wnętrz, reklama dla architektów wnętrz, klienci dla projektanta wnętrz, Meta Ads dla architektów wnętrz, pozyskiwanie klientów dla architekta wnętrz, sprzedaż usług projektowania wnętrz',
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Szymon Mroczkowski" />
    <meta name="theme-color" content="#050608" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="Archi Media" />
    <meta property="og:image" content="/assets/archimedia-logo.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/png" href="/assets/archimedia-symbol.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800;9..40,900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
