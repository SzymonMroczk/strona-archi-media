---
const conditions = [
  'Regularne uzupełnianie wyników rozmów',
  'Przesyłanie ustalonej części rozmów sprzedażowych do analizy',
  'Przerobienie szkolenia sprzedażowego',
  'Kontakt z leadami w ustalonym czasie',
  'Aktualizacja statusów leadów',
  'Wdrażanie rekomendacji omawianych na konsultacjach',
];
---

<section class="bg-archiDark px-5 py-10 text-archiWhite md:px-8 md:py-14">
  <div class="mx-auto max-w-7xl overflow-hidden rounded-[2.5rem] border border-archiBlue/25 bg-archiBlue/[0.12] p-7 shadow-glow md:p-12">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
      <div>
        <span class="section-label">Warunki</span>
        <h2 class="section-heading-dark mb-5">Kiedy system działa najlepiej?</h2>
        <p class="section-subheading-dark">
          Najlepsze efekty pojawiają się wtedy, gdy kampania, szybki kontakt z leadem, sprzedaż i analiza rozmów działają razem.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {conditions.map((condition) => (
          <div class="rounded-3xl border border-archiWhite/[0.10] bg-archiDark/[0.45] p-5">
            <div class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-archiBlue">
              <svg class="h-4 w-4 text-archiWhite" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="font-bold leading-snug text-archiWhite/[0.84]">{condition}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
