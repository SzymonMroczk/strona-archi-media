---
const wordOfMouth = [
  'Trudno skalować sprzedaż',
  'Brak wpływu na jakość klienta',
  'Planowanie miesięcy jest przypadkowe',
  'Brak powtarzalnego procesu',
  'Duża zależność od aktualnych poleceń',
];

const archiSystem = [
  'Stałe testowanie komunikatów',
  'Lepsza kontrola nad grupą docelową',
  'Proces obsługi każdego zgłoszenia',
  'Dane z kampanii i rozmów sprzedażowych',
  'Większa przewidywalność kolejnych rozmów',
];
---

<section class="section-padding bg-archiDark text-archiWhite">
  <div class="container-narrow">
    <div class="mb-14 max-w-3xl">
      <span class="section-label">Porównanie</span>
      <h2 class="section-heading-dark">Polecenia mogą pomagać. System pozwala rosnąć.</h2>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      <div class="rounded-[2.2rem] border border-archiWhite/[0.09] bg-archiWhite/[0.045] p-7 md:p-9">
        <div class="mb-7 flex items-center justify-between">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-archiWhite/[0.34]">Marketing z przypadku</p>
          <div class="h-3 w-3 rounded-full bg-archiWhite/25"></div>
        </div>
        <ul class="flex flex-col gap-4">
          {wordOfMouth.map((item) => (
            <li class="flex items-start gap-3 rounded-2xl border border-archiWhite/[0.06] bg-archiDark/50 p-4">
              <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full border border-archiWhite/20"></span>
              <p class="text-archiWhite/[0.58]">{item}</p>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative overflow-hidden rounded-[2.2rem] border border-archiBlue/[0.35] bg-archiBlue/[0.12] p-7 shadow-glow md:p-9">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-archiBlue/30 blur-3xl"></div>
        <div class="relative mb-7 flex items-center justify-between">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-archiBlue">System Archi Media</p>
          <div class="h-3 w-3 rounded-full bg-archiBlue"></div>
        </div>
        <ul class="relative flex flex-col gap-4">
          {archiSystem.map((item) => (
            <li class="flex items-start gap-3 rounded-2xl border border-archiBlue/25 bg-archiDark/[0.55] p-4">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-archiBlue text-archiWhite">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <p class="font-semibold text-archiWhite">{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
