---
import { services } from '../data/services';
---

<section id="zakres" class="section-padding bg-archiCream text-archiBlack">
  <div class="container-narrow">
    <div class="mb-14 max-w-3xl">
      <span class="section-label">Zakres</span>
      <h2 class="section-heading mb-6">Nie dostajesz samej kampanii. Dostajesz system rozwoju pracowni.</h2>
      <p class="section-subheading">
        Zakres dopasowuję do etapu, na którym jesteś. Inaczej wygląda pierwsze źródło leadów, a inaczej skalowanie pracowni i budowanie zespołu.
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <div class="group flex items-center gap-4 rounded-3xl border border-black/[0.08] bg-archiWhite p-5 transition-transform duration-200 hover:-translate-y-1 hover:shadow-card">
          <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-2xl bg-archiBlue/[0.10]">
            <div class="h-2 w-2 rounded-full bg-archiBlue"></div>
          </div>
          <p class="font-bold leading-snug text-archiBlack">{service}</p>
        </div>
      ))}
    </div>
  </div>
</section>
