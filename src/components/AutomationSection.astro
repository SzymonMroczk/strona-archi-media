---
import { automationItems } from '../data/services';
---

<section class="section-padding bg-archiBg border-t border-black/8">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Items -->
      <div class="order-2 lg:order-1">
        <div class="grid sm:grid-cols-2 gap-3">
          {automationItems.map((item) => (
            <div class="card flex items-start gap-3">
              <div class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-md bg-archiBlue/10 flex items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-archiBlue"></div>
              </div>
              <p class="text-sm font-medium text-archiBlack">{item}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 lg:order-2">
        <span class="section-label">Automatyzacje i CRM</span>
        <h2 class="section-heading mb-6">
          Leady nie mogą ginąć w wiadomościach
        </h2>
        <p class="section-subheading">
          Archimedia pomaga uporządkować obsługę zapytań przez automatyczne powiadomienia, statusy rozmów i prosty system CRM.
        </p>
      </div>
    </div>
  </div>
</section>
