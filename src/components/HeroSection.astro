---
const tags = ['Meta Ads', 'Sprzedaż', 'CRM', 'Proces klientów'];
const metrics = [
  { value: '80+', label: 'wdrożeń w branży wnętrz' },
  { value: '1 system', label: 'marketing, sprzedaż i obsługa' },
  { value: '0 chaosu', label: 'w obsłudze zapytań' },
];
const pipeline = [
  { step: '01', label: 'Strategia', sub: 'grupa docelowa i oferta' },
  { step: '02', label: 'Kampania', sub: 'formularz i komunikaty' },
  { step: '03', label: 'Kontakt', sub: 'szybki odzew do klienta' },
  { step: '04', label: 'Sprzedaż', sub: 'rozmowa i kwalifikacja' },
  { step: '05', label: 'Umowa', sub: 'projekt wnętrza zamiast samego zapytania' },
];
---

<section class="relative overflow-hidden bg-archiDark bg-archi-radial pt-16 md:pt-24">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-archiBlue/70 to-transparent"></div>
  <div class="absolute -left-32 top-24 h-72 w-72 rounded-full bg-archiBlue/20 blur-3xl"></div>
  <div class="absolute right-0 top-36 h-96 w-96 rounded-full bg-archiBlue/10 blur-3xl"></div>

  <div class="container-narrow relative pb-20 pt-10 md:pb-28 lg:pt-16">
    <div class="grid items-center gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:gap-14">
      <div>
        <div class="mb-7 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full border border-archiWhite/[0.10] bg-archiWhite/[0.06] px-3.5 py-2 text-xs font-bold uppercase tracking-[0.16em] text-archiWhite/[0.72] backdrop-blur">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="mb-7 max-w-5xl text-5xl font-black leading-[0.92] tracking-[-0.07em] text-archiWhite md:text-7xl lg:text-8xl">
          Przewidywalny system pozyskiwania klientów dla pracowni wnętrz
        </h1>

        <p class="section-subheading-dark mb-9 max-w-2xl">
          Archi Media łączy kampanie Meta Ads, sprzedaż, CRM i analizę rozmów, żeby Twoja pracownia nie była zależna wyłącznie od poleceń.
        </p>

        <div class="mb-10 flex flex-col gap-3 sm:flex-row">
          <a href="#kontakt" class="btn-primary">
            Umów konsultację strategiczną
          </a>
          <a href="#system" class="btn-secondary">
            Zobacz jak działa system
          </a>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          {metrics.map((metric) => (
            <div class="rounded-3xl border border-archiWhite/[0.08] bg-archiWhite/[0.04] p-5 backdrop-blur">
              <p class="text-2xl font-black tracking-[-0.04em] text-archiWhite">{metric.value}</p>
              <p class="mt-1 text-sm leading-snug text-archiWhite/[0.52]">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-5 rounded-[2.5rem] bg-archiBlue/20 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-[2.2rem] border border-archiWhite/[0.12] bg-[#0b0d13]/[0.92] p-4 shadow-glow backdrop-blur-xl md:p-6">
          <div class="mb-5 flex items-center justify-between rounded-3xl border border-archiWhite/[0.08] bg-archiWhite/[0.05] p-4">
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-archiWhite/40">Panel wzrostu</p>
              <p class="mt-1 text-lg font-black tracking-[-0.03em] text-archiWhite">Archi Media OS</p>
            </div>
            <div class="rounded-full bg-archiBlue px-3 py-1.5 text-xs font-extrabold text-archiWhite">Live</div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div class="rounded-3xl border border-archiWhite/[0.08] bg-archiWhite/[0.05] p-4">
              <p class="text-xs text-archiWhite/[0.42]">Leady</p>
              <p class="mt-2 text-3xl font-black tracking-[-0.05em] text-archiWhite">492</p>
            </div>
            <div class="rounded-3xl border border-archiWhite/[0.08] bg-archiWhite/[0.05] p-4">
              <p class="text-xs text-archiWhite/[0.42]">Rozmowy</p>
              <p class="mt-2 text-3xl font-black tracking-[-0.05em] text-archiWhite">118</p>
            </div>
            <div class="rounded-3xl border border-archiWhite/[0.08] bg-archiBlue p-4">
              <p class="text-xs text-archiWhite/70">Umowy</p>
              <p class="mt-2 text-3xl font-black tracking-[-0.05em] text-archiWhite">46</p>
            </div>
          </div>

          <div class="mt-4 rounded-[1.8rem] border border-archiWhite/[0.08] bg-archiWhite/[0.04] p-4">
            <div class="mb-4 flex items-center justify-between">
              <p class="text-sm font-bold text-archiWhite">Ścieżka od reklamy do umowy</p>
              <p class="text-xs text-archiWhite/40">5 etapów</p>
            </div>

            <div class="flex flex-col gap-3">
              {pipeline.map((item) => (
                <div class="group flex items-center gap-3 rounded-2xl border border-archiWhite/[0.06] bg-archiDark/70 p-3 transition-colors hover:border-archiBlue/40">
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl bg-archiBlue/[0.14] text-xs font-black text-archiBlue">
                    {item.step}
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-extrabold text-archiWhite">{item.label}</p>
                    <p class="truncate text-xs text-archiWhite/[0.45]">{item.sub}</p>
                  </div>
                  <div class="h-2 w-2 rounded-full bg-archiBlue"></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
