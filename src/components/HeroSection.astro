---
---

<section class="section-padding bg-archiBg pt-16 md:pt-24 overflow-hidden">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left content -->
      <div>
        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {['Marketing w branży architektonicznej', 'Meta Ads', 'Sprzedaż', 'Leady', 'Proces'].map((tag) => (
            <span class="text-xs font-medium bg-archiBlue/10 text-archiBlue px-3 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold leading-[1.1] text-archiBlack mb-6">
          Pozyskuj klientów do pracowni wnętrz w bardziej przewidywalny sposób
        </h1>

        <p class="section-subheading mb-10 max-w-xl">
          Archimedia pomaga architektom wnętrz uruchomić kampanie leadowe Meta Ads, uporządkować sprzedaż i zamieniać zapytania w podpisane umowy na projekty wnętrz.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="#kontakt" class="btn-primary text-base">
            Umów konsultację strategiczną
          </a>
          <a href="#system" class="btn-secondary text-base">
            Zobacz system działania
          </a>
        </div>
      </div>

      <!-- Right: Process mockup card -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="w-full max-w-sm bg-archiWhite rounded-3xl border border-black/10 p-8 shadow-xl shadow-black/5">
          <p class="text-xs font-semibold uppercase tracking-widest text-archiBlack/40 mb-6">System Archimedia</p>

          <div class="flex flex-col gap-3">
            {[
              { step: '01', label: 'Reklama', sub: 'Facebook & Instagram Ads' },
              { step: '02', label: 'Formularz', sub: 'Zbieranie zgłoszeń' },
              { step: '03', label: 'Kontakt', sub: 'Szybki odzew do leada' },
              { step: '04', label: 'Rozmowa', sub: 'Kwalifikacja i sprzedaż' },
              { step: '05', label: 'Oferta', sub: 'Prezentacja i negocjacje' },
              { step: '06', label: 'Umowa', sub: 'Podpisanie projektu' },
            ].map((item, i) => (
              <div class="flex items-center gap-4 group">
                <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-archiBlue/10 flex items-center justify-center">
                  <span class="text-xs font-bold text-archiBlue">{item.step}</span>
                </div>
                <div class="flex-1 flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold text-archiBlack">{item.label}</p>
                    <p class="text-xs text-archiBlack/50">{item.sub}</p>
                  </div>
                  {i < 5 && (
                    <svg class="w-4 h-4 text-archiBlue/30 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  )}
                  {i === 5 && (
                    <span class="text-xs font-semibold text-archiBlue bg-archiBlue/10 px-2.5 py-1 rounded-full">Cel</span>
                  )}
                </div>
              </div>
            ))}
          </div>

          <div class="mt-6 pt-5 border-t border-black/8">
            <p class="text-xs text-archiBlack/40 text-center">Celem nie jest reklama. Celem jest podpisana umowa.</p>
          </div>
        </div>

        <!-- Decorative element -->
        <div class="absolute -z-10 top-1/2 right-0 -translate-y-1/2 w-72 h-72 bg-archiBlue/5 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>
