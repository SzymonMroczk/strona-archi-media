---
const navLinks = [
  { label: 'Problem', href: '#problem' },
  { label: 'System', href: '#system' },
  { label: 'Efekty', href: '#efekty' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Kontakt', href: '#kontakt' },
  { label: 'Polityka prywatności', href: '#' },
];
---

<footer class="bg-archiBlack text-archiWhite py-14 md:py-16">
  <div class="container-narrow">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      <!-- Brand -->
      <div>
        <p class="text-xl font-display font-bold text-archiWhite mb-3">Archimedia</p>
        <p class="text-sm text-archiWhite/50 leading-relaxed mb-4">Marketing w branży architektonicznej</p>
        <p class="text-sm text-archiWhite/50">Szymon Mroczkowski</p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-archiWhite/30 mb-5">Nawigacja</p>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-archiWhite/60 hover:text-archiWhite transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Instagram -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-archiWhite/30 mb-5">Kontakt</p>
        <a
          href="https://www.instagram.com/archi_media__"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 text-sm text-archiWhite/60 hover:text-archiWhite transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @archi_media__
        </a>
      </div>
    </div>

    <div class="border-t border-archiWhite/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-archiWhite/30">
        &copy; {new Date().getFullYear()} Archimedia. Szymon Mroczkowski. Wszelkie prawa zastrzeżone.
      </p>
      <p class="text-xs text-archiWhite/20">Marketing w branży architektonicznej</p>
    </div>
  </div>
</footer>
