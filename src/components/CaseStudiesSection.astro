---
import { caseStudies } from '../data/caseStudies';
---

<section id="efekty" class="section-padding bg-archiBlack">
  <div class="container-narrow">
    <div class="max-w-2xl mb-12">
      <span class="text-archiBlue text-sm font-semibold uppercase tracking-widest mb-4 block">Efekty klientów</span>
      <h2 class="section-heading text-archiWhite mb-5">Efekty klientów</h2>
      <p class="text-lg text-archiWhite/60 leading-relaxed">
        Poniżej znajdziesz przykłady osób, które przed współpracą nie miały stabilnego źródła pozyskiwania klientów, a po wdrożeniu systemu zaczęły pozyskiwać więcej rozmów i podpisywać umowy na projekty wnętrz.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {caseStudies.map((cs) => (
        <div class="bg-archiWhite/5 border border-archiWhite/10 rounded-2xl p-6 flex flex-col gap-5 hover:border-archiBlue/40 transition-colors duration-200">
          <!-- Name -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-archiBlue/20 flex items-center justify-center flex-shrink-0">
              <span class="text-sm font-bold text-archiBlue">{cs.name.charAt(0)}</span>
            </div>
            <p class="font-semibold text-archiWhite">{cs.name}</p>
          </div>

          <!-- Before -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-archiWhite/30 mb-2">Przed</p>
            <p class="text-sm text-archiWhite/60 leading-relaxed">{cs.before}</p>
          </div>

          <!-- Separator -->
          <div class="flex items-center gap-2">
            <div class="flex-1 h-px bg-archiWhite/10"></div>
            <svg class="w-4 h-4 text-archiBlue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7M19 5l-7 7-7-7" />
            </svg>
            <div class="flex-1 h-px bg-archiWhite/10"></div>
          </div>

          <!-- After -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-archiBlue/70 mb-2">Po</p>
            <p class="text-sm text-archiWhite/90 font-medium leading-relaxed">{cs.after}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
