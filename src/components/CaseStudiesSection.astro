---
import { caseStudies } from '../data/caseStudies';
---

<section id="efekty" class="section-padding bg-archiCream text-archiBlack">
  <div class="container-narrow">
    <div class="mb-14 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <span class="section-label">Efekty klientów</span>
        <h2 class="section-heading">Przykłady pracowni, które zaczęły działać systemowo</h2>
      </div>
      <p class="section-subheading lg:pb-2">
        Poniżej znajdziesz skrócone przykłady efektów. Bez nazw pracowni, bo najważniejszy jest schemat zmiany, a nie przypadkowe chwalenie się cudzym brandem.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {caseStudies.map((cs) => (
        <article class="rounded-[2rem] border border-black/[0.08] bg-archiWhite p-6 shadow-card transition-transform duration-200 hover:-translate-y-1">
          <div class="mb-7 flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-archiBlue text-sm font-black text-archiWhite">
              {cs.name.charAt(0)}
            </div>
            <p class="font-black tracking-[-0.03em] text-archiBlack">{cs.name}</p>
          </div>

          <div class="mb-5 rounded-2xl bg-archiBg p-4">
            <p class="mb-2 text-xs font-black uppercase tracking-[0.16em] text-archiBlack/[0.35]">Przed</p>
            <p class="text-sm leading-relaxed text-archiBlack/[0.62]">{cs.before}</p>
          </div>

          <div class="rounded-2xl border border-archiBlue/25 bg-archiBlue/[0.08] p-4">
            <p class="mb-2 text-xs font-black uppercase tracking-[0.16em] text-archiBlue">Po</p>
            <p class="text-sm font-bold leading-relaxed text-archiBlack">{cs.after}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
