---
import { caseStudies } from '../data/caseStudies';

const funnel = [
  {
    label: 'Leady',
    value: '492',
    description: 'zgłoszenia z kampanii i formularzy',
    width: '100%',
  },
  {
    label: 'Rozmowy',
    value: '118',
    description: 'kontakty, które przeszły do rozmowy',
    width: '72%',
  },
  {
    label: 'Umowy',
    value: '46',
    description: 'podpisane współprace po procesie sprzedaży',
    width: '48%',
  },
];

const proofPoints = [
  'Liczymy nie tylko zgłoszenia, ale też rozmowy i podpisane umowy',
  'Każdy wynik jest opisany razem z wdrożeniem, które do niego doprowadziło',
  'Nazwy pracowni są pominięte, bo ważniejszy jest mechanizm działania niż cudzy brand',
];
---

<section id="efekty" class="section-padding overflow-hidden bg-archiCream text-archiBlack">
  <div class="container-narrow">
    <div class="mb-14 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <span class="section-label">Efekty klientów</span>
        <h2 class="section-heading">Wyniki pokazane jako proces, nie jako przypadkowe liczby</h2>
      </div>
      <p class="section-subheading lg:pb-2">
        Same screeny z panelu reklam nie mówią, czy pracownia realnie zarabia. Dlatego pokazuję drogę od zgłoszenia, przez rozmowę, aż do podpisanej umowy.
      </p>
    </div>

    <div class="mb-6 grid gap-5 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="relative overflow-hidden rounded-[2.4rem] bg-archiDark p-6 text-archiWhite shadow-glow md:p-8">
        <div class="absolute right-0 top-0 h-64 w-64 rounded-full bg-archiBlue/25 blur-3xl"></div>
        <div class="relative">
          <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div>
              <p class="mb-3 text-xs font-black uppercase tracking-[0.18em] text-archiBlue">Panel wyników</p>
              <h3 class="max-w-2xl text-3xl font-black tracking-[-0.045em] md:text-5xl">
                Od zainteresowania do podpisanej umowy
              </h3>
            </div>
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            {funnel.map((item) => (
              <div class="rounded-[1.6rem] border border-archiWhite/[0.10] bg-archiWhite/[0.055] p-5">
                <p class="text-sm font-bold text-archiWhite/[0.48]">{item.label}</p>
                <p class="mt-2 text-5xl font-black tracking-[-0.065em] text-archiWhite">{item.value}</p>
                <p class="mt-3 text-sm leading-snug text-archiWhite/[0.52]">{item.description}</p>
              </div>
            ))}
          </div>

          <div class="mt-6 rounded-[1.8rem] border border-archiWhite/[0.10] bg-[#0b0d13]/80 p-5">
            <div class="mb-5 flex items-center justify-between gap-4">
              <p class="text-sm font-extrabold text-archiWhite">Statystyki</p>
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-archiWhite/[0.36]">kampania plus sprzedaż</p>
            </div>
            <div class="space-y-4">
              {funnel.map((item) => (
                <div>
                  <div class="mb-2 flex items-center justify-between text-sm">
                    <span class="font-bold text-archiWhite/[0.78]">{item.label}</span>
                    <span class="font-black text-archiWhite">{item.value}</span>
                  </div>
                  <div class="h-3 overflow-hidden rounded-full bg-archiWhite/[0.08]">
                    <div class="h-full rounded-full bg-archiBlue" style={`width: ${item.width}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-[2.4rem] border border-black/[0.08] bg-archiWhite p-6 shadow-card md:p-8">
        <p class="mb-4 text-xs font-black uppercase tracking-[0.18em] text-archiBlue">Dlaczego to wygląda wiarygodniej</p>
        <h3 class="mb-6 text-3xl font-black tracking-[-0.045em] text-archiBlack">
          Wynik bez kontekstu niczego nie udowadnia
        </h3>
        <div class="space-y-3">
          {proofPoints.map((point) => (
            <div class="flex gap-3 rounded-3xl bg-archiBg p-4">
              <div class="mt-1 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-archiBlue text-xs font-black text-archiWhite">
                ✓
              </div>
              <p class="text-sm font-bold leading-relaxed text-archiBlack/[0.72]">{point}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {caseStudies.map((cs) => (
        <article class="rounded-[2.2rem] border border-black/[0.08] bg-archiWhite p-6 shadow-card md:p-7">
          <div class="mb-6 flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.18em] text-archiBlue">{cs.type}</p>
              <h3 class="mt-2 text-3xl font-black tracking-[-0.05em] text-archiBlack">{cs.name}</h3>
            </div>
            <div class="rounded-2xl bg-archiBlue/[0.10] px-4 py-3 text-right">
              <p class="text-2xl font-black tracking-[-0.05em] text-archiBlue">{cs.resultMetric}</p>
              <p class="mt-1 max-w-[9rem] text-xs font-bold leading-tight text-archiBlack/[0.55]">{cs.resultLabel}</p>
            </div>
          </div>

          <div class="mb-5 rounded-3xl bg-archiBg p-5">
            <p class="mb-2 text-xs font-black uppercase tracking-[0.16em] text-archiBlack/[0.35]">Punkt startu</p>
            <p class="text-sm font-semibold leading-relaxed text-archiBlack/[0.68]">{cs.context}</p>
          </div>

          <div class="mb-5 rounded-3xl border border-black/[0.08] p-5">
            <p class="mb-4 text-xs font-black uppercase tracking-[0.16em] text-archiBlack/[0.35]">Co zostało wdrożone</p>
            <div class="space-y-2">
              {cs.implementation.map((item) => (
                <div class="flex gap-3">
                  <div class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-archiBlue"></div>
                  <p class="text-sm font-bold leading-relaxed text-archiBlack/[0.70]">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <p class="text-sm font-semibold leading-relaxed text-archiBlack/[0.66]">{cs.resultDescription}</p>
        </article>
      ))}
    </div>
  </div>
</section>
