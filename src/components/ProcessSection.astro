---
import { processSteps } from '../data/processSteps';
---

<section id="proces" class="section-padding bg-archiBg text-archiBlack">
  <div class="container-narrow">
    <div class="mb-14 max-w-3xl">
      <span class="section-label">Proces współpracy</span>
      <h2 class="section-heading mb-6">Najpierw diagnoza. Później wdrożenie. Potem optymalizacja.</h2>
      <p class="section-subheading">
        Dzięki temu nie zaczynamy od przypadkowego ustawienia kampanii, tylko od zrozumienia oferty, procesu sprzedaży i celu biznesowego pracowni.
      </p>
    </div>

    <div class="relative grid gap-4 lg:grid-cols-5">
      {processSteps.map((step) => (
        <article class="group rounded-[2rem] border border-black/[0.08] bg-archiWhite p-6 shadow-card transition-transform duration-200 hover:-translate-y-1">
          <div class="mb-8 flex items-center justify-between">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-archiBlack text-sm font-black text-archiWhite">
              {step.number}
            </div>
            <div class="hidden h-px flex-1 bg-archiBlue/25 lg:ml-5 lg:block"></div>
          </div>
          <h3 class="mb-3 text-xl font-black tracking-[-0.04em] text-archiBlack">{step.title}</h3>
          <p class="text-sm leading-relaxed text-archiBlack/60">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
