---
import { systemSteps } from '../data/systemSteps';
---

<section id="system" class="section-padding bg-archiBg text-archiBlack">
  <div class="container-narrow">
    <div class="mb-14 grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div>
        <span class="section-label">Jak to działa</span>
        <h2 class="section-heading">System, który spina reklamę ze sprzedażą</h2>
      </div>
      <p class="section-subheading lg:pb-2">
        Każdy etap ma konkretną rolę. Reklama generuje zapytania, formularz kwalifikuje, kontakt otwiera rozmowę, a sprzedaż prowadzi do umowy.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-5">
      {systemSteps.map((step, i) => (
        <article class="relative overflow-hidden rounded-[2rem] border border-black/[0.08] bg-archiWhite p-6 shadow-card">
          <div class="absolute -right-10 -top-10 h-28 w-28 rounded-full bg-archiBlue/[0.08]"></div>
          <div class="relative mb-8 flex h-12 w-12 items-center justify-center rounded-2xl bg-archiBlack text-sm font-black text-archiWhite">
            {String(i + 1).padStart(2, '0')}
          </div>
          <h3 class="relative mb-3 text-xl font-black tracking-[-0.04em] text-archiBlack">{step.title}</h3>
          <p class="relative text-sm leading-relaxed text-archiBlack/60">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
