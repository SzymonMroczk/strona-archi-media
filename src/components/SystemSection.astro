---
import { systemSteps } from '../data/systemSteps';
---

<section id="system" class="section-padding bg-archiBg">
  <div class="container-narrow">
    <div class="max-w-2xl mb-14">
      <span class="section-label">Jak to działa</span>
      <h2 class="section-heading mb-5">System działania Archimedia</h2>
      <p class="section-subheading">
        Nie chodzi o samo uruchomienie reklamy. Archimedia buduje proces, który łączy strategię, kampanię, formularz, kontakt z leadem i sprzedaż.
      </p>
    </div>

    <div class="relative">
      <!-- Vertical connector line -->
      <div class="absolute left-6 top-8 bottom-8 w-px bg-archiBlue/20 hidden md:block"></div>

      <div class="flex flex-col gap-6">
        {systemSteps.map((step, i) => (
          <div class="flex gap-6 items-start group">
            <!-- Step indicator -->
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-archiBlue flex items-center justify-center z-10 shadow-md shadow-archiBlue/20">
              <span class="text-archiWhite text-sm font-bold">{String(i + 1).padStart(2, '0')}</span>
            </div>

            <!-- Content -->
            <div class="flex-1 card mb-0 hover:shadow-md hover:shadow-black/5 transition-shadow duration-200">
              <h3 class="text-lg font-semibold text-archiBlack mb-2">{step.title}</h3>
              <p class="text-archiBlack/60 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
